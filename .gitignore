# --- secrets ---
.env
# Google service-account key (contains a private key — NEVER commit)
job-agent-*.json
*service-account*.json
*service_account*.json

# --- python ---
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.eggs/
build/
dist/

# --- local state & personal data (not source) ---
# (comments must be on their own line; git has no inline comments)
# sqlite db
data/
# parsed resume profile (personal)
profile/
# your resume PDF (personal)
resume/
# generated digests (keep the dir via .gitkeep)
digests/*.md
!digests/.gitkeep

# --- os / editor ---
.DS_Store
.idea/
.vscode/

# --- local agent session state ---
.claude/
