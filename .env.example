# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# --- Anthropic (reasoning layer) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Adzuna (data layer) — get free keys at https://developer.adzuna.com/ ---
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key

# --- Optional: resume ---
# Absolute path to your resume PDF. Parsed ONCE into profile/profile.json and
# re-parsed only if the file changes. Defaults to ./resume/resume.pdf if unset.
RESUME_PATH=/absolute/path/to/your_resume.pdf

# --- Optional: email nudge (Gmail SMTP) ---
# SMTP_APP_PASSWORD is a Gmail *app password* (Google Account → Security →
# 2-Step Verification → App passwords), NOT your normal login password.
# If unset, the email step is skipped (the website still publishes).
SMTP_USER=you@gmail.com
SMTP_APP_PASSWORD=your_16_char_app_password
# NOTIFY_EMAIL defaults to muhammad.e.eltahir@gmail.com; override here if needed.
# NOTIFY_EMAIL=you@gmail.com

# --- Optional: published site URL (once GitHub Pages is enabled) ---
# SITE_URL=https://<your-username>.github.io/<repo>/

# --- Optional: Google Drive (master profile from your resumes/cover letters) ---
# Absolute path to a Google service-account JSON key (read-only Drive). Enable the
# Drive API for the project and share your resume/cover-letter folder (Viewer) with
# the service-account email. If unset, `master-profile` is unavailable and scoring
# falls back to the single resume profile.
# GOOGLE_SERVICE_ACCOUNT_JSON=/absolute/path/to/service-account.json
#
# Writing drafts to YOUR Drive uses a one-time user sign-in (OAuth), because a service
# account can't own files on a personal Google account. Create an OAuth "Desktop app"
# client (Cloud Console -> Credentials), download its JSON, point this at it, then run
# `job-agent auth`. Scope is the minimal drive.file (only files the app creates).
# GOOGLE_OAUTH_CLIENT_SECRET=/absolute/path/to/oauth-desktop-client.json
# GOOGLE_OAUTH_TOKEN_PATH=profile/google_oauth_token.json   # (default; where the token is cached)
# Optional: write drafts into a specific existing folder instead of an auto-created one.
# GOOGLE_DRIVE_FOLDER_ID=the_folder_id_from_its_drive_url
